{
  "name": "gentic",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "keywords": [
    "pi-package",
    "gentic",
    "suite"
  ],
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "scripts": {
    "check": "npm run check:pi-api",
    "check:pi-api": "node scripts/check-pi-extension-api.mjs",
    "test": "node --experimental-strip-types --test test/**/*.test.ts"
  },
  "pi": {
    "extensions": [
      "./extensions",
      "./extensions/**/index.ts"
    ],
    "skills": [
      "./skills",
      "./extensions/**/skills",
      "!./skills/**/README.md",
      "!./extensions/**/skills/**/README.md"
    ],
    "prompts": [
      "./prompts/**/*.md",
      "./extensions/**/prompts/**/*.md",
      "!./prompts/**/README.md",
      "!./extensions/**/prompts/**/README.md"
    ],
    "themes": [
      "./themes/**/*.json",
      "./extensions/**/themes/**/*.json"
    ]
  }
}
